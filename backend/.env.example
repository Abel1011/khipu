# --- Qwen Cloud (DashScope, OpenAI-compatible) ---
# Get your API key at https://home.qwencloud.com/api-keys
# Pay-as-you-go keys (sk-...) use the URL below. Token Plan keys (sk-sp-...) must use
# https://token-plan.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=
QWEN_REASONER=qwen3.7-plus
QWEN_EXTRACTOR=qwen3.6-flash
QWEN_JUDGE=qwen3.7-plus
QWEN_RERANKER=qwen3.6-flash
QWEN_THINKING_ROLES=judge
QWEN_EMBEDDER=text-embedding-v3
QWEN_EMBED_DIM=1024

# --- Infra ---
QDRANT_URL=http://localhost:6333
POSTGRES_URL=postgresql+psycopg://khipu:khipu@localhost:5432/khipu

# Optional: local cross-encoder reranker (needs the "local" extra).
# Default is the LLM reranker (Qwen-native, uses the reasoner model).
USE_LOCAL_RERANKER=false
